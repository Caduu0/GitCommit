# Copie este arquivo para .env e preencha com suas credenciais reais.
# O arquivo .env está no .gitignore e NUNCA deve ser commitado.

DISCORD_BOT_TOKEN=SEU_TOKEN_DO_DISCORD_AQUI
DISCORD_CHANNEL_ID=0
GITHUB_REPO_URL=https://github.com/SeuUsuario/SeuRepositorioMirror.git
GITHUB_PAT=SEU_PAT_DO_GITHUB_AQUI
GIT_AUTHOR_NAME=Seu Nome
GIT_AUTHOR_EMAIL=seu@email.com
SCHEDULER_ENABLED=true
SCHEDULER_CRON=0 0 20 * * *
